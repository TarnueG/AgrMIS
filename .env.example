# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Supabase vars: keep until all pages are migrated to the custom backend (Phases 2–7)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Stripe — TEST MODE publishable key only (starts with pk_test_)
# NEVER set a live key here. Get from dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── Backend (backend/.env) ───────────────────────────────────────────────────
# PostgreSQL 18 connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/AMIS_DB

# JWT signing secrets — use long random strings (e.g. openssl rand -hex 32)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Express server port (Vite proxies /api to this port)
PORT=3001

# Allowed CORS origin (must match Vite dev server port)
FRONTEND_URL=http://localhost:8080

# Seed script defaults (used only when running: cd backend && npm run seed)
ADMIN_EMAIL=admin@agritech.local
ADMIN_PASSWORD=Admin@1234

# Stripe — TEST MODE secret key (starts with sk_test_)
# NEVER commit a live key. Get from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_

# Stripe webhook signing secret — get from: stripe listen --print-secret (CLI) or Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_
