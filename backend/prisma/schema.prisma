generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model roles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @unique @db.VarChar(60)
  description      String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  role_permissions      role_permissions[]
  subsystem_permissions subsystem_permissions[]
  users                 users[]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model users {
  id                                          String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id                                     String                    @db.Uuid
  full_name                                   String                    @db.VarChar(150)
  email                                       String                    @db.VarChar(255)
  password_hash                               String
  phone                                       String?                   @db.VarChar(30)
  username                                    String?                   @db.VarChar(50)
  profile_picture_url                         String?
  last_login                                  DateTime?                 @db.Timestamptz(6)
  deleted_at                                  DateTime?                 @db.Timestamptz(6)
  created_at                                  DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                                  DateTime                  @default(now()) @db.Timestamptz(6)
  aquaculture_records                         aquaculture_records[]
  asset_maintenance_logs                      asset_maintenance_logs[]
  asset_usage_logs                            asset_usage_logs[]
  attendance_logs                             attendance_logs[]
  audit_logs                                  audit_logs[]
  contracts                                   contracts[]
  crop_production_records                     crop_production_records[]
  daily_production_logs                       daily_production_logs[]
  distribution_logs                           distribution_logs[]
  employees                                   employees[]
  fish_harvest_records                        fish_harvest_records[]
  journal_entries                             journal_entries[]
  livestock_health_logs                       livestock_health_logs[]
  livestock_records                           livestock_records[]
  purchase_orders                             purchase_orders[]
  quality_checks                              quality_checks[]
  reorder_alerts                              reorder_alerts[]
  report_definitions                          report_definitions[]
  report_runs                                 report_runs[]
  sales_orders_sales_orders_created_byTousers sales_orders[]            @relation("sales_orders_created_byTousers")
  sales_orders_sales_orders_updated_byTousers sales_orders[]            @relation("sales_orders_updated_byTousers")
  sessions                                    sessions[]
  stock_transactions                          stock_transactions[]
  task_assignments                            task_assignments[]
  role                                        roles                     @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  work_orders                                 work_orders[]

  @@index([role_id], map: "idx_users_role_id")
}

model sessions {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @unique
  expires_at DateTime @db.Timestamptz(6)
  ip_address String?  @db.Inet
  user_agent String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_sessions_expires")
  @@index([user_id], map: "idx_sessions_user_id")
}

model farm_profiles {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @db.VarChar(200)
  country                 String?                   @db.VarChar(100)
  region                  String?                   @db.VarChar(100)
  operational_sectors     String[]
  settings                Json                      @default("{\"currency\": \"USD\", \"timezone\": \"UTC\"}")
  deleted_at              DateTime?                 @db.Timestamptz(6)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  aquaculture_records     aquaculture_records[]
  assets                  assets[]
  audit_logs              audit_logs[]
  cart_items              cart_items[]
  contractor_payments     contractor_payments[]
  contractors             contractors[]
  contracts               contracts[]
  crop_production_records crop_production_records[]
  customers               customers[]
  daily_production_logs   daily_production_logs[]
  dashboard_snapshots     dashboard_snapshots[]
  employees               employees[]
  equipment_requests      equipment_requests[]
  financial_accounts      financial_accounts[]
  journal_entries         journal_entries[]
  land_parcels            land_parcels[]
  livestock_records       livestock_records[]
  marketing_orders        marketing_orders[]
  module_configurations   module_configurations[]
  parcel_requests         parcel_requests[]
  personnel_wages         personnel_wages[]
  prices                  prices[]
  purchase_orders         purchase_orders[]
  quality_checks          quality_checks[]
  sales_orders            sales_orders[]
  stock_items             stock_items[]
  subsystem_permissions   subsystem_permissions[]
  suppliers               suppliers[]
  task_assignments        task_assignments[]
  work_orders             work_orders[]
}

model employees {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String?            @db.Uuid
  farm_id               String?            @db.Uuid
  full_name             String             @db.VarChar(150)
  employee_code         String?            @unique @db.VarChar(60)
  employment_type       String             @db.VarChar(30)
  job_title             String?            @db.VarChar(100)
  department            String?            @db.VarChar(100)
  sector                String?            @db.VarChar(30)
  phone                 String?            @db.VarChar(30)
  national_id           String?            @db.VarChar(60)
  date_hired            DateTime?          @db.Date
  contract_end_date     DateTime?          @db.Date
  daily_wage            Decimal?           @db.Decimal(10, 2)
  monthly_salary        Decimal?           @db.Decimal(12, 2)
  notes                 String?
  deleted_at            DateTime?          @db.Timestamptz(6)
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  updated_at            DateTime           @default(now()) @db.Timestamptz(6)
  personnel_id          String?            @db.VarChar(30)
  date_of_birth         DateTime?          @db.Date
  place_of_birth        String?            @db.VarChar(150)
  email                 String?            @db.VarChar(255)
  address               String?
  bank_id               String?            @db.VarChar(100)
  status                String             @default("active") @db.VarChar(20)
  suspension_reason     String?
  suspension_expires_at DateTime?          @db.Timestamptz(6)
  terminated_at         DateTime?          @db.Timestamptz(6)
  asset_usage_logs      asset_usage_logs[]
  assets                assets[]
  attendance_logs       attendance_logs[]
  farm                  farm_profiles?     @relation(fields: [farm_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                  users?             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  personnel_wages       personnel_wages[]
  task_assignments      task_assignments[]

  @@unique([farm_id, national_id], map: "unique_employee_national_id_per_farm")
  @@index([farm_id], map: "idx_employees_farm")
  @@index([employment_type], map: "idx_employees_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model aquaculture_records {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id              String?                @db.Uuid
  recorded_by          String                 @db.Uuid
  pond_identifier      String                 @db.VarChar(80)
  species              String                 @db.VarChar(100)
  stocking_date        DateTime?              @db.Date
  initial_stock_count  Int?
  current_stock_count  Int?
  stocking_density     Decimal?               @db.Decimal(8, 2)
  pond_area_sqm        Decimal?               @db.Decimal(10, 2)
  water_source         String?                @db.VarChar(100)
  status               String                 @default("active") @db.VarChar(30)
  notes                String?
  deleted_at           DateTime?              @db.Timestamptz(6)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  farm_profiles        farm_profiles?         @relation(fields: [farm_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                users                  @relation(fields: [recorded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fish_harvest_records fish_harvest_records[]
  work_orders          work_orders[]

  @@index([farm_id], map: "idx_aqua_farm")
  @@index([pond_identifier], map: "idx_aqua_pond")
  @@index([recorded_by], map: "idx_aqua_recorded_by")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model asset_maintenance_logs {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  asset_id          String    @db.Uuid
  performed_by      String    @db.Uuid
  maintenance_type  String    @db.VarChar(30)
  description       String
  cost              Decimal?  @db.Decimal(12, 2)
  service_provider  String?   @db.VarChar(200)
  maintenance_date  DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  next_service_date DateTime? @db.Date
  downtime_hours    Decimal?  @db.Decimal(6, 2)
  outcome           String?
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  assets            assets    @relation(fields: [asset_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users     @relation(fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([asset_id], map: "idx_maintenance_asset")
  @@index([maintenance_date(sort: Desc)], map: "idx_maintenance_date")
}

model asset_usage_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
