  notes         String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  assets        assets    @relation(fields: [asset_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users?    @relation(fields: [authorized_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employees     employees @relation(fields: [used_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([asset_id], map: "idx_asset_usage_asset")
  @@index([start_time(sort: Desc)], map: "idx_asset_usage_date")
}

