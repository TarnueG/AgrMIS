{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**",     "run": { "serviceId": "amis-api", "region": "us-central1" } },
      { "source": "/uploads/**", "run": { "serviceId": "amis-api", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}